{
  "plugins": {
    "superpowers": {
      "enabled": true
    },
    "supabase": {
      "enabled": true
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .cursor/hooks/gsd-check-update.js"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node .cursor/hooks/gsd-statusline.js"
  },
  "agentBenchmarkGuard": {
    "enabled": false,
    "how_to_enable": "Add a FileSave hook to run: node .cursor/hooks/agent-benchmark-guard.js"
  }
}
