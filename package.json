{
  "name": "mineru-local-monorepo",
  "private": true,
  "scripts": {
    "dev": "run-p dev:web dev:api",
    "dev:web": "cd apps/web && npm run dev",
    "dev:api": "cd apps/api && uvicorn app.main:app --reload --port 8000",
    "setup:api": "cd apps/api && uv pip install -e .",
    "setup:web": "cd apps/web && npm install"
  },
  "devDependencies": {
    "npm-run-all2": "^7.0.2"
  }
}
